# This is Git's per-user configuration file.
[user]
  name = Junichi Kobayashi
  email = nnujabok@gmail.com
[pull]
  rebase = true
[alias]
  delete-merged-branch = "!f () { git checkout $1; git branch --merged|egrep -v '\\*|main|master'|xargs git branch -d; };f"
  push-base-to-origin = "!f () { git branch|egrep 'main|master'|sed -E 's/^.{2}(.*)$/\\1/'|xargs git push origin; };f"
  pull-base-from-origin = "!f () { git branch|egrep 'main|master'|sed -E 's/^.{2}(.*)$/\\1/'|xargs git pull origin; };f"
[ghq]
  root = ~/git
[fetch]
  prune = true
[pager]
  log = diff-highlight | less
  show = diff-highlight | less
  diff = diff-highlight | less
[diff]
  indentHeuristic = true
[commit]
  verbose = true
[init]
  defaultBranch = master
[wt]
	basedir = .worktrees
